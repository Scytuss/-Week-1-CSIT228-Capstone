<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>


<?import javafx.scene.layout.StackPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.dormitory.MainController">
    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
            <Label text="Dormitory and Boarding House Management System" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        </HBox>
    </top>
    <left>
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
            <Button text="Dashboard" onAction="#handleDashboard"/>
            <Button text="Add Tenant" onAction="#handleAddTenant"/>
            <Button text="Rooms"/>
            <Button text="Payments" onAction="#handlePayment"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="10" style="-fx-padding: 10;">
            <StackPane fx:id="contentPane"/>
            <Label text="Tenant List" style="-fx-font-size: 14px;" />

            <TableView fx:id="tenantTable">
                <columns>
                    <TableColumn text="ID" prefWidth="100"/>
                    <TableColumn text="Name" prefWidth="200"/>
                    <TableColumn text="Room" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
