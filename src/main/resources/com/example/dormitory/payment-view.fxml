<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.dormitory.PaymentController">

    <top>

        <HBox spacing="10"
              alignment="CENTER_LEFT"
              style="-fx-padding: 15;
                     -fx-background-color: #34495e;">

            <Label text="Payment Management"
                   style="-fx-text-fill: white;
                          -fx-font-size: 18px;
                          -fx-font-weight: bold;"/>

        </HBox>

    </top>

    <center>

        <VBox spacing="15"
              style="-fx-padding: 20;">

            <TableView fx:id="paymentTable"
                       prefHeight="450">

                <columns>

                    <TableColumn fx:id="nameColumn"
                                 text="Tenant Name"
                                 prefWidth="150"/>

                    <TableColumn fx:id="roomColumn"
                                 text="Room"
                                 prefWidth="100"/>

                    <TableColumn fx:id="paidColumn"
                                 text="Paid"
                                 prefWidth="80"/>

                    <TableColumn fx:id="rentColumn"
                                 text="Monthly Rent ($)"
                                 prefWidth="130"/>

                    <TableColumn fx:id="debtColumn"
                                 text="Total Debt ($)"
                                 prefWidth="130"/>

                    <TableColumn fx:id="missedColumn"
                                 text="Missed Months"
                                 prefWidth="120"/>

                    <TableColumn fx:id="evictedColumn"
                                 text="Evicted"
                                 prefWidth="100"/>

                </columns>

            </TableView>

            <HBox spacing="10">

                <Button text="Mark Paid"
                        onAction="#handleMarkPaid"/>

                <Button text="Miss Payment"
                        onAction="#handleMissPayment"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>
