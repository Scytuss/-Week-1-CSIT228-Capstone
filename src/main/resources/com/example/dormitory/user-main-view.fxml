<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.dormitory.UserViewController">
    <left>
        <VBox spacing="15"
              prefWidth="200"
              style="-fx-background-color: #2C3E50; -fx-padding: 20;">

            <Button text="Dashboard"
                    prefWidth="160"
                    onAction="#handleUserDashboard"
                    style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

            <Button text="Payment"
                    prefWidth="160"
                    onAction="#handlePayment"
                    style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

            <Button text="Transaction History"
                    prefWidth="160"
                    onAction="#handleTransactionHistory"
                    style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

            <Button text="Rent Notification"
                    prefWidth="160"
                    onAction="#handleRentNotification"
                    style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane"
                   style="-fx-background-color: #ECF0F1;"/>
    </center>

</BorderPane>
