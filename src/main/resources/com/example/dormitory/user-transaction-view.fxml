<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dormitory.UserTransactionController"
      style="-fx-padding: 30; -fx-background-color: #ECF0F1;">

    <Label text="TRANSACTION HISTORY"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

    <Separator prefWidth="700"/>

    <HBox spacing="20" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="Total Paid" style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
            <Label fx:id="totalPaidLabel" text="₱0.00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #27AE60;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="Payments Made" style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
            <Label fx:id="paymentsCountLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="Current Due Date" style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
            <Label fx:id="currentDueDateLabel" text="---" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;"/>
        </VBox>
    </HBox>

    <TableView fx:id="transactionTable" prefHeight="350" prefWidth="800"
               style="-fx-background-color: white; -fx-background-radius: 8;">

        <columns>
            <TableColumn fx:id="transactionIdCol" text="Transaction ID" prefWidth="140"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="paymentDateCol" text="Payment Date" prefWidth="150"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="dueDateCol" text="Due Date" prefWidth="130"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="amountPaidCol" text="Amount Paid" prefWidth="120"
                         style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="lateFeeCol" text="Late Fee" prefWidth="100"
                         style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="paymentMethodCol" text="Payment Method" prefWidth="130"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="newDueDateCol" text="New Due Date" prefWidth="150"
                         style="-fx-alignment: CENTER;"/>
        </columns>

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>


    <Label fx:id="noRecordsLabel" text="No payment records found"
           style="-fx-text-fill: #95A5A6; -fx-font-style: italic;"
           visible="false" managed="false"/>

</VBox>
