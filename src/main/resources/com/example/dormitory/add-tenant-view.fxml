<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dormitory.AddTenantController"
      spacing="15"
      alignment="TOP_CENTER"
      style="-fx-padding: 30; -fx-background-color: #ECF0F1;">

    <Label text="ADD TENANT"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

    <Separator prefWidth="400"/>

    <VBox spacing="15"
          style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
          prefWidth="400">

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Name:" style="-fx-font-weight: bold; -fx-text-fill: #7F8C8D;" prefWidth="80"/>
            <TextField fx:id="nameField" promptText="Enter Name"
                       style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #BDC3C7; -fx-border-radius: 5;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Contact:" style="-fx-font-weight: bold; -fx-text-fill: #7F8C8D;" prefWidth="80"/>
            <TextField fx:id="contactField" promptText="Enter Contact"
                       style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #BDC3C7; -fx-border-radius: 5;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Email:" style="-fx-font-weight: bold; -fx-text-fill: #7F8C8D;" prefWidth="80"/>
            <TextField fx:id="emailField" promptText="Enter Email"
                       style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #BDC3C7; -fx-border-radius: 5;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Room:" style="-fx-font-weight: bold; -fx-text-fill: #7F8C8D;" prefWidth="80"/>
            <ComboBox fx:id="roomBox" promptText="Select Room" prefWidth="200"
                      style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-border-radius: 5;"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Monthly Rent:" style="-fx-font-weight: bold; -fx-text-fill: #7F8C8D;" prefWidth="80"/>
            <TextField fx:id="rentField" promptText="Enter Rent Amount"
                       style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #BDC3C7; -fx-border-radius: 5;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <Separator/>

        <HBox spacing="20" alignment="CENTER">
            <Button text="Save" onAction="#handleSave"
                    style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="Cancel" onAction="#handleCancel"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>

    </VBox>

</VBox>
