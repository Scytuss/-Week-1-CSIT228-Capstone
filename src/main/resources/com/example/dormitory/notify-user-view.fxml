<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="15"
      style="-fx-padding: 30;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dormitory.NotifyUserController">

    <Label text="RENT NOTIFICATION"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

    <Label fx:id="tenantNameLabel"
           style="-fx-font-size: 16px;"/>

    <Label fx:id="dueDateLabel"
           style="-fx-font-size: 16px;"/>

    <Label fx:id="monthlyRentLabel"
           style="-fx-font-size: 16px;"/>

    <Label fx:id="statusLabel"/>

    <Label fx:id="messageLabel"
           wrapText="true"
           maxWidth="520"
           style="-fx-font-size: 15px; -fx-text-fill: #34495E;"/>

    <Button text="Notify Rent Due"
            onAction="#handleNotifyRentDue"/>
</VBox>
